# ═══════════════════════════════════════════════════════════
#  .gitignore — RVCE Todo App
# ═══════════════════════════════════════════════════════════

# ── Dependencies ─────────────────────────────────────────
node_modules/
client/node_modules/
server/node_modules/

# ── Build Output ─────────────────────────────────────────
client/dist/

# ── Environment Variables ────────────────────────────────
# .env files contain secrets — never commit them!
# Use .env.example as a template instead.
.env
server/.env
client/.env

# ── Logs ─────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── OS Files ─────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini

# ── IDE / Editor ─────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# ── Coverage & Testing ──────────────────────────────────
coverage/
*.lcov

# ── Docker ───────────────────────────────────────────────
.dockerignore
*.dbsqlite
